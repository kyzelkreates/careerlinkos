# ============================================================
# CareerLink OS™ — Environment Variables
# CareerLink OS Powered 4P3X Intelligent AI™ Created by Kyzel Kreates™
#
# Copy this file to .env and fill in your values.
# Add secrets to Vercel / hosting environment variables — NOT .git.
# Without Supabase keys the app runs in Demo / Local mode.
# ============================================================

# ── Supabase (Primary Live Backend) ──────────────────────────
# Only VITE_ prefixed keys are safe for frontend use.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Firebase (Config-only — adapter not installed yet) ────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AWS / Amplify (Config-only — adapter not installed yet) ───
VITE_AWS_REGION=
VITE_AWS_API_ENDPOINT=

# ── Custom Backend (Config-only — adapter not installed yet) ──
VITE_CUSTOM_API_BASE_URL=
VITE_CUSTOM_PUBLIC_CLIENT_KEY=

# ── Organisation Defaults (Optional) ─────────────────────────
VITE_ORG_NAME=CareerLink Employment Support
VITE_WEEKLY_TARGET_HOURS=35

# ── AI Providers (Optional — configure in Settings > AI) ─────
# Leave blank to use Local / Rule-based AI mode (offline, no key needed)
VITE_OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=
VITE_GROQ_API_KEY=
VITE_ANTHROPIC_API_KEY=

# ============================================================
# NEVER include these in frontend .env or VITE_ vars
# These are backend/server-only secrets
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=   ← backend only, never frontend
# DATABASE_URL=                ← backend only
# JWT_SECRET=                  ← backend only
# PRIVATE_KEY=                 ← backend only
# STRIPE_SECRET_KEY=           ← backend only
# WEBHOOK_SECRET=              ← backend only
# AWS_SECRET_ACCESS_KEY=       ← backend only (IAM secret)
# AWS_ACCESS_KEY_ID=           ← backend only (IAM key)
# AWS_SESSION_TOKEN=           ← backend only
# FIREBASE_SERVICE_ACCOUNT=    ← backend only
# GOOGLE_APPLICATION_CREDENTIALS= ← backend only
# ADMIN_TOKEN=                 ← backend only
